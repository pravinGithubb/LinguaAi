<?xml version="1.0" encoding="utf-8"?>
<!--
  Home screen — Lernix-inspired layout.
  Sections (top → bottom):
    1. Title bar          ("LinguaAI - AI Language Tutor")
    2. AI Chat hero card  (full-width, gradient, illustrated character, "Learn with AI" CTA)
    3. Vocabulary + Translate row (two equal-width coloured cards)
    4. Practice card      (full-width, "New" badge — opens Speaking Quiz)
    5. More Options pill  (compact, opens the FeatureBottomSheet with the rest)

  Every card has alpha=0 + a translation so the fragment can animate them
  in via AnimUtils for the staggered entrance feel.

  Background uses the existing app/background colour token; cards use the
  Lernix palette (blue/yellow/green/blue) for instant visual recognition.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        android:paddingTop="20dp"
        android:paddingBottom="96dp">

        <!-- ── 1. Title row: app name + target language flag chip ─────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LinguaAI - AI Language Tutor"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <!-- Flag chip — opens Change Language on tap. Shows the
                 current target language so users know "what they're
                 learning right now" at a glance. -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_lang_flag"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                app:cardBackgroundColor="@color/surface"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tv_lang_flag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:paddingHorizontal="14dp"
                    android:textSize="18sp"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ── 2. AI Chat hero card ───────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_ai_chat"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_hero_height"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp"
            android:alpha="0"
            android:translationY="20dp">

            <!-- Background gradient -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_card_hero_blue"/>

            <!-- AI tutor illustration. Vector — replace with a raster
                 PNG of the same name in drawable-xxxhdpi/ for higher fidelity. -->
            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/illus_ai_tutor"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="12dp"
                android:contentDescription="AI tutor"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="start|center_vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Chat Tutor"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Real-life conversation\npractice with AI"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_learn_ai"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Learn with AI"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    app:cornerRadius="20dp"
                    app:backgroundTint="#FFFFFF"
                    android:layout_marginTop="14dp"
                    android:paddingHorizontal="20dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── 3. Vocabulary + Translate row ──────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_card_height"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_vocabulary"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFD568"
                android:alpha="0"
                android:translationX="-30dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/illus_books"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Vocabulary"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="bottom"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vocabulary"
                        android:textColor="#3D2C00"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expand your vocabulary\neffortlessly"
                        android:textColor="#5C4400"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_translate"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#5DB075"
                android:alpha="0"
                android:translationX="30dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/illus_globe"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Translate"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="bottom"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Translate"
                        android:textColor="#0F3D1F"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Improve language skills\nthrough translation"
                        android:textColor="#1F4F30"
                        android:textSize="12sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ── 4. Practice (Speaking Quiz) ────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_practice"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_card_height"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp"
            android:alpha="0"
            android:translationY="20dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_card_practice_teal"/>

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/illus_practice"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="20dp"
                android:contentDescription="Practice"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="start|center_vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Practice"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Learn to speak language"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- "New" badge top-right -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="14dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_chip_red"
                android:layout_gravity="top|end"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="14dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── 4b. Word of Day + Quiz row ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_card_height"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Word of Day (purple) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_word_of_day"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#9B7FCC">

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="📖"
                    android:textSize="36sp"
                    android:gravity="center"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="bottom"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Word of Day"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A new word, daily"
                        android:textColor="#F0E8FA"
                        android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quiz (coral) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_quiz"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FF8B6B">

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="🎯"
                    android:textSize="36sp"
                    android:gravity="center"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="bottom"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quiz"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10 AI questions"
                        android:textColor="#FFE5DD"
                        android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ── 5. More options pill ───────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_more_options"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E8EAF0"
            app:cardBackgroundColor="@color/surface"
            android:alpha="0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="More features"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to explore"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginEnd="10dp"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:contentDescription="Open more"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
