<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Lernix-style title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">
            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_left"
                android:tint="@color/text_primary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:onClick="onBackPressed"
                android:contentDescription="Back"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PDF Reader"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp"
            android:layout_marginTop="-16dp">

            <!-- Open PDF button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_pdf"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📂  Open PDF File"
                android:textSize="15sp"
                android:backgroundTint="@color/primary"
                app:cornerRadius="16dp"
                android:layout_marginBottom="12dp"
                android:alpha="0" />

            <!-- PDF info card (empty state) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_pdf_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EDE7F6"
                android:layout_marginBottom="12dp"
                android:alpha="0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ℹ️" android:textSize="22sp" android:layout_marginEnd="12dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Uses Android's built-in PDF renderer — no internet needed. Works best with text-based PDFs."
                        android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PDF Viewer container -->
            <LinearLayout
                android:id="@+id/pdf_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Status bar -->
                <TextView
                    android:id="@+id/tv_pdf_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No PDF loaded"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <!-- Page display card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="8dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_pdf_page"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:scaleType="fitCenter" />

                        <ProgressBar
                            android:id="@+id/progress_pdf"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:visibility="gone" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Navigation row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_prev_page"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="◀  Prev"
                        android:enabled="false"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="12dp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_page_indicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginHorizontal="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_next_page"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Next  ▶"
                        android:enabled="false"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="12dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- Translate button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_translate_page"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="🌍  Translate This Page"
                    android:textSize="15sp"
                    android:backgroundTint="@color/accent"
                    app:cornerRadius="16dp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <!-- Translation result -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Card.Standard"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌍  Translation"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="10dp" />
                        <TextView
                            android:id="@+id/tv_translation_pdf"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/primary"
                            android:lineSpacingExtra="4dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
