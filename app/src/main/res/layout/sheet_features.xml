<?xml version="1.0" encoding="utf-8"?>
<!--
  Bottom sheet showing all the secondary features that don't fit on the
  Lernix-style home screen. Opens when the user taps the "More features"
  pill on home.

  Layout: drag-handle, "All Features" title, scrollable 2-column grid of
  small feature tiles. Each tile has an emoji icon, title, one-line
  subtitle.

  All click handlers live in FeatureBottomSheet.java — kept that way so
  the same bottom sheet could be reused from another screen later.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_drag_handle"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Features"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap any feature to open"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"/>

        <!-- Scrollable grid of feature tiles -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="520dp"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/grid_features"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
