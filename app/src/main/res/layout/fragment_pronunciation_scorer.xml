<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Lernix-style title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">
            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_left"
                android:tint="@color/text_primary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:onClick="onBackPressed"
                android:contentDescription="Back"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pronunciation"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="16dp"
            android:paddingBottom="24dp" android:layout_marginTop="-16dp">

            <TextView android:id="@+id/tv_language_hint"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"/>

            <ProgressBar android:id="@+id/progress_bar"
                android:layout_width="36dp" android:layout_height="36dp"
                android:layout_gravity="center" android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <!-- Phrase area -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_phrase_area"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Card.Elevated" android:layout_marginBottom="12dp" android:alpha="0">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Practice Phrase" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_get_phrase"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="🔀 New Phrase" android:textSize="12sp"
                            android:backgroundTint="@color/primary" app:cornerRadius="10dp"/>
                    </LinearLayout>

                    <TextView android:id="@+id/tv_phrase_display"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Tap 'New Phrase' to get a practice sentence"
                        android:textSize="20sp" android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:gravity="center" android:padding="16dp"
                        android:lineSpacingExtra="4dp"
                        android:background="@drawable/bg_lang_chip"
                        android:layout_marginBottom="12dp"/>

                    <!-- Custom phrase input -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Or enter your own phrase:" android:textSize="12sp"
                        android:textColor="@color/text_secondary" android:layout_marginBottom="6dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <EditText android:id="@+id/et_custom_phrase"
                            android:layout_width="0dp" android:layout_height="44dp"
                            android:layout_weight="1" android:hint="Type a phrase…"
                            android:textSize="14sp" android:background="@drawable/bg_lang_chip"
                            android:paddingHorizontal="12dp" android:layout_marginEnd="8dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_custom_phrase"
                            android:layout_width="wrap_content" android:layout_height="44dp"
                            android:text="Use" android:textSize="13sp"
                            android:backgroundTint="@color/accent" app:cornerRadius="10dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mic area -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_mic_area"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Card.Standard" android:layout_marginBottom="12dp" android:alpha="0">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp" android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_speak"
                        android:layout_width="match_parent" android:layout_height="60dp"
                        android:text="🎤  Speak"
                        android:textSize="16sp" android:backgroundTint="@color/primary"
                        app:cornerRadius="16dp" android:enabled="false"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:id="@+id/tv_spoken_result"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Press Speak and say the phrase above"
                        android:textSize="14sp" android:textColor="@color/text_secondary"
                        android:gravity="center" android:lineSpacingExtra="3dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Score result card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_score_result"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Card.Elevated" android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="24dp" android:gravity="center">

                    <!-- Score display -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center"
                        android:layout_marginBottom="12dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center"
                            android:background="@drawable/bg_avatar_ai"
                            android:padding="20dp">
                            <TextView android:id="@+id/tv_score_number"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="48sp" android:textStyle="bold"
                                android:textColor="@color/primary" android:alpha="0"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="/ 100" android:textSize="14sp"
                                android:textColor="@color/text_secondary"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:paddingStart="20dp">
                            <TextView android:id="@+id/tv_score_grade"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="20sp" android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:layout_marginBottom="6dp"/>
                            <TextView android:id="@+id/tv_score_feedback"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:textSize="13sp" android:textColor="@color/text_secondary"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Tips -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="12dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="💡  Pronunciation Tips" android:textSize="14sp"
                        android:textStyle="bold" android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tv_score_tips"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/text_secondary"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
