<?xml version="1.0" encoding="utf-8"?>
<!--
  Change Language screen.

  The user's native + target language are normally set once during onboarding.
  This screen lets them change either, any time, from the home screen.

  Two MaterialCardView-wrapped AutoCompleteTextViews (matching the
  onboarding pattern) plus a Save button at the bottom. Lernix-style
  airy spacing, no clutter.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Header row: back arrow + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp">
            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_left"
                android:tint="@color/text_primary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:onClick="onBackPressed"
                android:contentDescription="Back"
                android:layout_marginStart="-8dp"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change Language"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Update the language you speak and the language you're learning"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="24dp"/>

        <!-- ── Native language card ─────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_native"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E8EAF0"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="14dp"
            android:alpha="0"
            android:translationX="-30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I speak"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    app:boxStrokeColor="@color/primary"
                    app:hintEnabled="false">
                    <AutoCompleteTextView
                        android:id="@+id/spinner_native"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Target (learning) language card ─────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_target"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E8EAF0"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="24dp"
            android:alpha="0"
            android:translationX="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I'm learning"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    app:boxStrokeColor="@color/primary"
                    app:hintEnabled="false">
                    <AutoCompleteTextView
                        android:id="@+id/spinner_target"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Save button ──────────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Changes"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="26dp"
            app:backgroundTint="@color/primary"
            android:alpha="0"/>

        <!-- Helpful note (Hindi etc) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tip: the Speaking Quiz now supports Hindi too — pick Hindi as your learning language to practice with Hindi sentences."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="2dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
