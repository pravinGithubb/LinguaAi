<?xml version="1.0" encoding="utf-8"?>
<!--
  Chat screen — Lernix-inspired redesign.

  Visual structure (top → bottom):
    1. Sparse top row     ✕ close (left) · ⚙ tool icons (right)
    2. Avatar tile        140dp × 180dp portrait, top-left, scrolls with content
    3. Greeting bubble    appears just below the avatar — first message
    4. Message stream     RecyclerView with the rest of the conversation
    5. Typing indicator   floating dots above the input row
    6. Input row          rounded text field + circular send button

  Important: every @+id from the previous chat layout is preserved
  (rv_messages, et_message, btn_send, dot1/2/3, typing_indicator,
  tv_chat_title) so ChatFragment.java keeps compiling without changes.

  Note on the avatar:
    - Uses @drawable/ai_tutor_avatar (vector). Drop a real PNG/JPG with
      the same name into drawable-xxhdpi/ to override.
    - The "live" green dot signals the AI is online — purely decorative.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- ── 1. Sparse top action row ───────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/top_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close chat"/>

        <!-- Hidden title kept so binding.tvChatTitle stays valid -->
        <TextView
            android:id="@+id/tv_chat_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:visibility="gone"/>

        <!-- Right-side decorative icons (mirrors Lernix). Mic, language,
             history, robot — purely visual for now, no click handlers. -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_top_action_circle_red">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🎙"
                android:textSize="14sp"
                android:textColor="#FFFFFF"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_top_action_circle_dark">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌐"
                android:textSize="14sp"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_top_action_circle_dark">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🤖"
                android:textSize="14sp"/>
        </FrameLayout>
    </LinearLayout>

    <!-- ── 2. Avatar tile (top-left, scrolls with the message stream) ── -->
    <!--
      The avatar lives inside a NestedScrollView paired with the
      RecyclerView via a vertical LinearLayout container. But because
      RecyclerView wants to control its own scrolling, the cleanest setup
      is: avatar + greeting are HEADER views that scroll out of view as
      messages arrive — implemented by anchoring them above the
      RecyclerView and letting the RV occupy the rest of the screen.
      To match Lernix's behaviour where the avatar STAYS visible at the
      top, we keep it pinned here. If you'd prefer it to scroll away with
      messages, move this block into a header item in ChatAdapter.
    -->
    <FrameLayout
        android:id="@+id/avatar_container"
        android:layout_width="140dp"
        android:layout_height="180dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_avatar_tile"
        app:layout_constraintTop_toBottomOf="@id/top_actions"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/illus_ai_tutor"
            android:scaleType="centerCrop"
            android:contentDescription="AI tutor avatar"/>

        <!-- Subtle expand affordance bottom-right of the avatar -->
        <TextView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:text="⤢"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_avatar_expand_chip"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Live status dot top-right -->
        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_online"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"/>
    </FrameLayout>

    <!-- ── 3. Greeting bubble (anchored under the avatar) ─────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/greeting_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/bubble_ai_border"
        app:cardBackgroundColor="@color/bubble_ai"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="80dp"
        app:layout_constraintTop_toBottomOf="@id/avatar_container"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello! How can I assist you today?"
            android:textColor="@color/bubble_ai_text"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── 4. Message stream ──────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbarStyle="outsideOverlay"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/greeting_bubble"
        app:layout_constraintBottom_toTopOf="@id/input_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── 5. Typing indicator (floats above the input row) ───────────── -->
    <LinearLayout
        android:id="@+id/typing_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bubble_ai_shape"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/input_card"
        app:layout_constraintStart_toStartOf="parent">

        <View android:id="@+id/dot1"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/typing_dot" android:layout_marginEnd="4dp"/>
        <View android:id="@+id/dot2"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/typing_dot" android:layout_marginEnd="4dp"/>
        <View android:id="@+id/dot3"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/typing_dot"/>
    </LinearLayout>

    <!-- ── 6. Input row ──────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/input_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                style="@style/Input.Outlined">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_message"
                    android:imeOptions="actionSend"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="5"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_send"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="➤"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Btn.Send"
                app:cornerRadius="25dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
