    <!-- Top book: blue, slightly rotated visual via offset -->
    <path
        android:pathData="M20,28 L20,42 L58,42 L58,28 Z"
        android:fillColor="#4C7CE6"/>
    <path
        android:pathData="M20,28 L58,28 L58,30 L20,30 Z"
