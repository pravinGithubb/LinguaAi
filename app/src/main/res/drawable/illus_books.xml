<?xml version="1.0" encoding="utf-8"?>
<!--
  Vocabulary card illustration — stack of three coloured books with a
  pencil. Designed to read at 80×80dp. Replace with a raster PNG of the
  same name in drawable-xxxhdpi/ for higher fidelity.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Bottom book: red -->
    <path
        android:pathData="M10,55 L10,68 L66,68 L66,55 Z"
        android:fillColor="#E64C4C"/>
    <path
        android:pathData="M10,55 L66,55 L66,57 L10,57 Z"
