<?xml version="1.0" encoding="utf-8"?>
<!--
  Background tile used behind the AI tutor portrait in chat. Soft pearl
  white with a thin edge so it reads as a contained portrait card.
  Replace src on the ImageView with a real photo if you have one — the
  background frame stays the same.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:startColor="#F0F4FA"
        android:endColor="#D5DEEC"
        android:angle="135"/>
    <corners android:radius="16dp"/>
    <stroke android:width="1dp" android:color="#C8D1E5"/>
</shape>
