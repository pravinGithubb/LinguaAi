# ============================================================
#  LinguaAI — Android Project .gitignore
#  Place this file at the project root (alongside build.gradle)
# ============================================================


# ── Gradle build output ──────────────────────────────────────
.gradle/
build/
app/build/

# Gradle wrapper jar (keep wrapper properties, skip the jar)
gradle/wrapper/gradle-wrapper.jar

# ── API Keys — NEVER commit these ───────────────────────────
# Keys live in local.properties — each dev keeps their own copy
local.properties
keystore.properties
*.jks
*.keystore


# ── Android Studio IDE files ─────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml
.idea/deploymentTargetDropDown.xml
captures/


# ── Generated sources ────────────────────────────────────────
app/schemas/


# ── Test results & reports ───────────────────────────────────
**/test-results/
**/test-report/


# ── OS junk ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db


# ── Lint ─────────────────────────────────────────────────────
lint/
lint-results*.xml
lint-results*.html


# ── ProGuard mapping (generated, not source) ─────────────────
app/build/outputs/mapping/


# ── Claude / AI session artifacts ───────────────────────────
*.zip


# ── Already-tracked folders (force untrack these) ────────────
.gradle/
gradle/
build/
app/build/

# ── Android Studio misc ──────────────────────────────────────
*.hprof
.cxx/
.navigation/
*.orig

# ── Windows thumbnail cache ──────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Local config — never commit ──────────────────────────────
local.properties
!local.properties.example